#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(CDPATH= cd "$SCRIPT_DIR/.." && pwd)"
BUILD_DIR="$ROOT_DIR/build/latex"
DIST_DIR="$ROOT_DIR/dist"
OUTPUT_PDF="$DIST_DIR/migaki-whitepaper.pdf"

if ! command -v pdflatex >/dev/null 2>&1; then
  printf 'Error: pdflatex was not found on PATH.\n' >&2
  printf 'Install a LaTeX distribution that provides pdflatex, then rerun this script.\n' >&2
  exit 127
fi

mkdir -p "$BUILD_DIR" "$DIST_DIR"

cd "$ROOT_DIR/paper"

i=1
while [ "$i" -le 3 ]; do
  pdflatex \
    -interaction=nonstopmode \
    -halt-on-error \
    -file-line-error \
    -output-directory "$BUILD_DIR" \
    main.tex
  i=$((i + 1))
done

cp "$BUILD_DIR/main.pdf" "$OUTPUT_PDF"
printf 'Wrote %s\n' "$OUTPUT_PDF"
